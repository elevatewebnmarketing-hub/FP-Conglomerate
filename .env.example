# Copy to `frontend/.env` and `admin/.env` (Vite loads `.env` from each package root).
# Secrets (JWT signing, DB, peppers) live on the Elevate API host — not in this repo.

# --- Elevate Central API (required for contact form + staff admin) ---
# Base URL with no trailing slash (e.g. https://api.example.com)
VITE_PUBLIC_API_BASE_URL=REPLACE_WITH_YOUR_API_ORIGIN

# Publishable site key from API seed/ops — sent as X-Site-Key on POST /v1/public/leads
VITE_PUBLIC_SITE_KEY=

# Lead metadata (must match API / OpenAPI enums)
VITE_PUBLIC_LEAD_INDUSTRY_VERTICAL=construction
VITE_PUBLIC_LEAD_SOURCE_SYSTEM=marketing-site
VITE_PUBLIC_LEAD_FORM_ID=contact-main

# Optional: default org slug on staff login form (admin app)
VITE_PUBLIC_ORGANIZATION_SLUG=demo-org

# --- Existing URLs (not the API) ---
# Marketing site canonical URL for SEO/sitemap (frontend build)
# VITE_SITE_URL=https://www.example.com

# Public marketing URL for admin “back” link
# VITE_PUBLIC_SITE_URL=http://localhost:8080

# Admin app URL for marketing footer link
# VITE_ADMIN_URL=http://localhost:5174
